# Datos pesados (reproducibles desde la semilla; no se versionan)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.csv
*.parquet

# Python
__pycache__/
*.pyc
.venv/
venv/
.ipynb_checkpoints/

# Streamlit / entorno
.streamlit/secrets.toml
.env

# Logs de ejecución (reproducibles; no se versionan)
outputs/*_log.txt

# Figuras generadas por el notebook (reproducibles; no se versionan durante el EDA)
outputs/figures/
notebooks/*.png

# Sistema operativo / editor
.DS_Store
Thumbs.db
.vscode/

# Excepción puntual: la muestra (28 MB) SÍ se versiona para desplegar el dashboard en
# Streamlit Community Cloud (la nube clona el repo y necesita el dato). Es la única
# salida derivada que versionamos; el resto sigue fuera de git.
!data/processed/muestra_usuarios.parquet
